generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("TEST_KITCHEN_DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  passwordHash String
  createdAt    DateTime @default(now())
}

model Recipe {
  id               String          @id @default(cuid())
  title            String
  tags             String[]
  isFavorite       Boolean         @default(false)
  images           String[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  currentVersionId String?         @unique
  versions         RecipeVersion[]
  currentVersion   RecipeVersion?  @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  menus            Menu[]
  branches         RecipeBranch[]
}

model Menu {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  recipes   Recipe[]
}

model RecipeBranch {
  id                   String          @id @default(cuid())
  recipeId             String
  recipe               Recipe          @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  name                 String
  isDefault            Boolean         @default(false)
  order                Int             @default(0)
  createdFromVersionId String?
  createdFromVersion   RecipeVersion?  @relation("BranchSource", fields: [createdFromVersionId], references: [id], onDelete: SetNull)
  currentVersionId     String?         @unique
  currentVersion       RecipeVersion?  @relation("BranchCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions             RecipeVersion[] @relation("BranchVersions")
  createdAt            DateTime        @default(now())

  @@unique([recipeId, name])
}

model RecipeVersion {
  id               String        @id @default(cuid())
  recipeId         String
  versionNumber    Int
  changeNote       String?
  createdAt        DateTime      @default(now())
  data             Json
  branchId         String?
  recipe           Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  branch           RecipeBranch? @relation("BranchVersions", fields: [branchId], references: [id], onDelete: SetNull)
  currentFor       Recipe?       @relation("CurrentVersion")
  currentForBranch RecipeBranch? @relation("BranchCurrentVersion")
  sourcedBranches  RecipeBranch[] @relation("BranchSource")

  @@unique([recipeId, versionNumber])
}
